# ============================================================
# OdinHub — .gitignore
# Static site for Cloudflare Pages
# ============================================================

# OS Files
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Node (in case tools/scripts added later)
node_modules/
npm-debug.log
yarn-error.log

# Build / Output (future-proofing)
dist/
build/
.cache/

# Logs
*.log

# Environment / Secrets (if ever added)
.env
.env.*
